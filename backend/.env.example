# Copie este arquivo para .env e ajuste se necessário.
# A connection string abaixo bate com o docker-compose.yml da raiz.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestao_ativos?schema=public"

# Porta da API
PORT=3333

# Segredo do JWT — em produção use um valor longo e aleatório
JWT_SECRET="troque-este-segredo-em-producao"
JWT_EXPIRES_IN="1d"

# Chave-mestra do cofre de senhas (AES-256). Em produção, use um valor longo,
# aleatório e guardado fora do código (variável de ambiente / KMS / cofre).
# Se esta chave mudar, os segredos já gravados não poderão mais ser decifrados.
CREDENTIALS_KEY="troque-esta-chave-mestra-do-cofre"

# Origem permitida no CORS (front em dev)
CORS_ORIGIN="http://localhost:5173"
